rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'Admin';
    }
    
    // Helper function to check if user is inspector
    function isInspector() {
      return isAuthenticated() && getUserData().role == 'Inspector';
    }
    
    // Helper function to check if user is client
    function isClient() {
      return isAuthenticated() && getUserData().role == 'Client';
    }
    
    // Users collection
    match /users/{userId} {
      // Allow users to read their own document or if admin
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Allow user creation during signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow users to update their own profile or if admin
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // Machines collection
    match /machines/{machineId} {
      // Everyone authenticated can read machines
      allow read: if isAuthenticated();
      
      // Only admins can create, update, or delete machines
      allow write: if isAdmin();
    }
    
    // Inspections collection - MOST PERMISSIVE FOR AUTHENTICATED USERS
    match /inspections/{inspectionId} {
      // ALLOW ALL AUTHENTICATED USERS TO READ ALL INSPECTIONS
      // This ensures dashboard works without permission issues
      allow read: if isAuthenticated();
      
      // Allow all authenticated users to create inspections
      allow create: if isAuthenticated();
      
      // Allow all authenticated users to update inspections
      allow update: if isAuthenticated();
      
      // Allow admins to delete inspections
      allow delete: if isAdmin();
    }
    
    // Forms collection
    match /forms/{formId} {
      // Everyone authenticated can read forms
      allow read: if isAuthenticated();
      
      // Only admins can create, update, or delete forms
      allow write: if isAdmin();
    }
    
    // Assignments collection
    match /assignments/{assignmentId} {
      // Allow authenticated users to read assignments
      allow read: if isAuthenticated();
      
      // Allow all authenticated users to create/update assignments
      allow write: if isAuthenticated();
    }
    
    // Reports collection
    match /reports/{reportId} {
      // Allow authenticated users to read reports
      allow read: if isAuthenticated();
      
      // Allow all authenticated users to create/update reports
      allow write: if isAuthenticated();
    }
    
    // Activities collection
    match /activities/{activityId} {
      // Allow authenticated users to read activities
      allow read: if isAuthenticated();
      
      // Allow all authenticated users to create/update activities
      allow write: if isAuthenticated();
    }
    
    // Pending Users collection - for signup requests
    match /pendingUsers/{requestId} {
      // Allow unauthenticated users to create signup requests
      allow create: if true;
      
      // Allow admins to read all pending requests
      allow read: if isAdmin();
      
      // Allow admins to delete (reject/approve) pending requests
      allow delete: if isAdmin();
    }
    
    // Meta collection for seeding tracking
    match /_meta/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
